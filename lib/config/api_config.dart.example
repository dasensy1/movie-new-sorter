class ApiConfig {
  /// TMDB API Key
  /// Получите ключ бесплатно на: https://www.themoviedb.org/settings/api
  /// 
  /// Инструкция:
  /// 1. Зарегистрируйтесь на https://www.themoviedb.org
  /// 2. Перейдите в Settings -> API -> Create
  /// 3. Заполните форму (Application Name: Via Films, Application URL: можно указать localhost)
  /// 4. Скопируйте API Key (v3 auth) и вставьте ниже
  static const String tmdbApiKey = 'YOUR_TMDB_API_KEY_HERE';
  
  /// Базовый URL TMDB API
  static const String tmdbBaseUrl = 'https://api.themoviedb.org/3';
  
  /// Базовый URL для изображений
  static const String imageBaseUrl = 'https://image.tmdb.org/t/p/w300';
}
